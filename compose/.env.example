NGINX_IMAGE=docker.io/library/nginx:1.27-alpine

HEX_CORE_PORT=8080
RE_INDICATORS_CALCULATION_PORT=8081
ARTIFACT_SERVER_PORT=8082

HEX_CORE_SERVER_HOST=0.0.0.0
HEX_CORE_SERVER_PORT=8080
HEX_CORE_SERVER_REQUEST_MAX_BYTES=1048576
HEX_CORE_LOG_LEVEL=info
HEX_CORE_METRICS_ENABLED=false

REGISTRY_MODE=catalog
REGISTRY_CATALOG_FILE=/config/registry/catalog.json
REGISTRY_ALLOWED_HOSTS=artifact-server
REGISTRY_REQUIRE_HTTPS=false
REGISTRY_CACHE_ENABLED=false
REGISTRY_CACHE_TTL_SECS=300

IO_ADAPTER_ID=memory

AUTH_MODE=none
AUTH_ALLOW_INSECURE_NONE=true
AUTH_NONE_SUBJECT=local-demo-user
AUTH_NONE_ROLES=demo
AUTH_NONE_SCOPES=models:read records:read records:write

CALC_SERVER_HOST=0.0.0.0
CALC_SERVER_PORT=8080
CALC_HTTP_TIMEOUT_SECS=15

MODEL_VERSION=0.0.4
